DB_NAME=deutsch_chatbot
DB_USER=postgres
DB_PASSWORD=burry the light
DB_HOST=localhost
DB_PORT=5432
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN_HOURS=24
# Optional fallback if you prefer a single connection string:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/german_scenario
GROQ_API_KEY=you api key
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_STRUCTURED_MODEL=openai/gpt-oss-20b
